# DecoTV Environment Variables Example
# Copy this file to .env.local and fill in your values

# Storage Configuration
# Options: 'localstorage' | 'redis' | 'upstash' | 'kvrocks'
NEXT_PUBLIC_STORAGE_TYPE=localstorage

# User Registration
# Set to 'true' to enable user self-registration (requires redis/upstash/kvrocks storage)
NEXT_PUBLIC_ENABLE_REGISTRATION=false

# Search result display
# Options: 'infinite' | 'pagination'
NEXT_PUBLIC_SEARCH_RESULT_LOAD_MODE=infinite

# Redis Configuration (if using 'redis')
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Upstash Redis Configuration (if using 'upstash' - Recommended for Vercel/ClawCloud)
# Note: Use UPSTASH_URL and UPSTASH_TOKEN (not UPSTASH_REDIS_REST_*)
UPSTASH_URL=
UPSTASH_TOKEN=

# Kvrocks Configuration (if using 'kvrocks')
KVROCKS_URL=

# Admin Configuration
ADMIN_PASSWORD=your_admin_password_here
# Auth mode: password（默认，需要登录）| public（免登录家庭模式，仅建议可信内网）
NEXT_PUBLIC_AUTH_MODE=password
# public 模式下是否同时开放后台。风险极高，默认关闭
PUBLIC_ALLOW_ADMIN=false

# Douban proxy
# Options: auto | direct | server | cors-proxy-zwei | cmliussss-cdn-tencent | cmliussss-cdn-ali | custom
NEXT_PUBLIC_DOUBAN_PROXY_TYPE=auto
NEXT_PUBLIC_DOUBAN_PROXY=
# Options: auto | direct | server | img3 | cmliussss-cdn-tencent | cmliussss-cdn-ali | custom
NEXT_PUBLIC_DOUBAN_IMAGE_PROXY_TYPE=auto
NEXT_PUBLIC_DOUBAN_IMAGE_PROXY=

# 可选：外部元数据服务
# 豆瓣 API Key（未配置时保持现有降级行为）
DOUBAN_API_KEY=
# TMDB v3 API Key。未配置时 TMDB 功能静默降级
TMDB_API_KEY=
# TMDB 正向代理地址，例如 http://127.0.0.1:7890
TMDB_PROXY=
# TMDB 反向代理地址，优先级高于 TMDB_PROXY，例如 https://tmdb.example.com
TMDB_REVERSE_PROXY=

# 可选：私人影库初始配置（也可在 /admin 后台中配置）
# OpenList 服务地址，例如 https://openlist.example.com
OPENLIST_URL=
# OpenList Token。建议只在服务端环境中保存
OPENLIST_TOKEN=
# OpenList 扫描根目录，默认 /Media
OPENLIST_ROOT_PATH=/Media
# Emby 服务地址，例如 http://127.0.0.1:8096
EMBY_URL=
# Emby API Key
EMBY_API_KEY=
# Emby 用户 ID（可选，用于播放进度同步）
EMBY_USER_ID=
# Jellyfin 服务地址，例如 http://127.0.0.1:8096
JELLYFIN_URL=
# Jellyfin API Key
JELLYFIN_API_KEY=
# Jellyfin 用户 ID（可选，用于播放进度同步）
JELLYFIN_USER_ID=
# PanSou 代理请求超时，单位毫秒
PANSOU_PROXY_TIMEOUT_MS=15000

# FFmpeg HLS transfer (Task 2 server-side encrypted HLS download channel)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
# 官方 Docker 镜像会内置 /app/.cache/ffmpeg-downloads 可写目录；本地开发保持相对路径即可
FFMPEG_DOWNLOAD_DIR=.cache/ffmpeg-downloads
FFMPEG_MAX_CONCURRENT_JOBS=2
FFMPEG_JOB_RETENTION_MS=86400000

# M3U8 广告分段过滤（在 /api/detail、/api/search 等返回的 episodes URL 上自动改写）
# 优先级：管理后台 AdFilterConfig.enabled > 此环境变量 > 默认开
# 'true' / '1' = 开（默认），'false' / '0' = 关
# 客户端可通过 ?adfilter=false 在 URL 上临时禁用（用于调试/对照原始时间轴）
ENABLE_AD_FILTER=true
# 可选：m3u8 代理 URL 签名密钥；未设置时复用 AUTH_SECRET/PASSWORD/ADMIN_PASSWORD
# M3U8_PROXY_SIGNING_SECRET=

# 高级阈值（一般不用改，UI 不暴露；改坏可能误删正片）
# AD_FILTER_MIN_DURATION=3       # 广告段最短时长（秒）
# AD_FILTER_MAX_DURATION=120     # 广告段最长时长（秒），超过此值的 group 永远不被判为广告
# AD_FILTER_MAX_SEGMENTS=15      # 单个 discontinuity group 最多包含多少个 segment 才可能被判为广告

# Development
NODE_ENV=development
